{
  "name": "@ezeep/ezeep-js",
  "version": "1.0.0-alpha.0",
  "description": "A JavaScript library to enable easy and fast printing on any web application uising ezeep Blue.",
  "author": "Thinprint GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezeep/ezeep-js.git"
  },
  "main": "dist/index.cjs.js",
  "module": "loader/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "loader/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/ezeep-js/ezeep-js.esm.js",
  "files": [
    "dist/",
    "loader/",
    "www/"
  ],
  "scripts": {
    "build": "stencil build --docs",
    "start": "stencil build --dev --watch --serve",
    "generate": "stencil generate",
    "stylelint": "stylelint \"**/*.scss\" --fix",
    "prettier": "prettier \"**/*.{json,ts,tsx,md,html}\" --write",
    "format": "npm run stylelint && npm run prettier",
    "prepare": "patch-package"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.8.0",
    "@cortado-holding/colors": "1.1.12",
    "@cortado-holding/utils": "^1.0.1",
    "@stencil/core": "^4.43.4",
    "fetch-intercept": "^2.4.0",
    "i18next": "21.2.4",
    "whatwg-fetch": "^3.6.2"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "3.0.0",
    "@stencil/angular-output-target": "^1.3.1",
    "@stencil/sass": "^3.2.3",
    "@stencil/store": "^2.2.2",
    "@types/css-font-loading-module": "^0.0.6",
    "@types/node": "^15.14.9",
    "dotenv": "^10.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^2.4.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "stylelint": "^16.25.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-order": "^7.0.0",
    "stylelint-prettier": "^1.2.0"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "htmlWhitespaceSensitivity": "strict",
    "overrides": [
      {
        "files": "src/data/locales/*.json",
        "options": {
          "tabWidth": 4
        }
      }
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-prettier"
    ],
    "plugins": [
      "stylelint-prettier",
      "stylelint-order"
    ],
    "rules": {
      "prettier/prettier": true,
      "order/order": [
        "dollar-variables",
        "custom-properties",
        "declarations",
        "rules",
        "at-rules"
      ],
      "order/properties-alphabetical-order": true
    }
  }
}
